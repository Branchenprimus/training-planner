APP_ORIGIN=http://localhost:3000
NUXT_STRAVA_CLIENT_ID=your_strava_client_id
NUXT_STRAVA_CLIENT_SECRET=your_strava_client_secret
NUXT_STRAVA_REDIRECT_URI=http://localhost:3000/api/auth/strava/callback
NUXT_STRAVA_SCOPES=activity:read_all,profile:read_all
NUXT_SQLITE_PATH=/data/training-planner.sqlite
NUXT_SYNC_INTERVAL_MINUTES=30
NUXT_SESSION_COOKIE_NAME=training_planner_state
NUXT_SESSION_SECRET=replace-with-a-long-random-string
APP_PORT=3000
